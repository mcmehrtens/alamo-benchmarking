# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version

# uv
.uv-cache/
uv.lock.bak

# Build artifacts
dist/
build/
*.egg-info/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Per-machine artifacts. Committed: .db, .manifest.json, alamo-benchmark.log.
# Gitignored: per-rep subprocess logs (compile/regression/SCP/render subprocesses)
# and rendered media (frames + encoded gif/webm/mp4).
results/*/run_*/logs/
results/*/run_*/render/
# SQLite WAL/SHM files — transient, never useful to commit alongside the .db
results/*/run_*/*.db-wal
results/*/run_*/*.db-shm

# Alamo submodule build artifacts (the submodule itself is tracked)
alamo/tmp_build_dir/
alamo/Bin/
alamo/build/
alamo/*.log

# Generated post-processing report (run `uv run alamo-benchmark report` to rebuild).
/report/
